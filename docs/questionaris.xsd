<?xml version="1.0" encoding="UTF-8"?>

<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">

<xsd:simpleType name="tref-decimal-or-empty">
  <xsd:union memberTypes="tref-decimal empty-string" />
</xsd:simpleType>

<xsd:simpleType name="dateTime-or-empty">
  <xsd:union memberTypes="xsd:dateTime empty-string" />
</xsd:simpleType>

<xsd:simpleType name="mag-decimal-or-empty">
  <xsd:union memberTypes="mag-decimal empty-string" />
</xsd:simpleType>

<xsd:simpleType name="lat-decimal-or-empty">
  <xsd:union memberTypes="lat-decimal empty-string" />
</xsd:simpleType>
<xsd:simpleType name="lon-decimal-or-empty">
  <xsd:union memberTypes="lon-decimal empty-string" />
</xsd:simpleType>
<xsd:simpleType name="sr-epsg-or-empty">
  <xsd:union memberTypes="sr-epsg empty-string" />
</xsd:simpleType>

<xsd:simpleType name="elev-decimal-or-empty">
  <xsd:union memberTypes="elev-decimal empty-string" />
</xsd:simpleType>
<xsd:simpleType name="indicador_exactitud_geo-or-empty">
  <xsd:union memberTypes="indicador_exactitud_geo empty-string" />
</xsd:simpleType>

<xsd:simpleType name="tref-decimal"> 
	<xsd:restriction base="xsd:decimal"><xsd:minInclusive value="0.0"/><xsd:maxInclusive value="4102444800.0"/> 
	</xsd:restriction>
</xsd:simpleType> 

<xsd:simpleType name="mag-decimal"> 
	<xsd:restriction base="xsd:decimal"><xsd:minInclusive value="-10.0"/><xsd:maxInclusive value="+10.0"/>
	<xsd:totalDigits value="3"/><xsd:fractionDigits value="1"/>
	</xsd:restriction>
</xsd:simpleType> 
					
<xsd:simpleType name="lat-decimal"> 
	<xsd:restriction base="xsd:decimal"><xsd:minInclusive value="-90.0"/><xsd:maxInclusive value="+90.0"/>
	</xsd:restriction>
</xsd:simpleType>  
<xsd:simpleType name="lon-decimal"> 
	<xsd:restriction base="xsd:decimal"><xsd:minInclusive value="-180.0"/><xsd:maxInclusive value="+180.0"/>
	</xsd:restriction>
</xsd:simpleType> 
<xsd:simpleType name="sr-epsg">	
	<xsd:restriction base="xsd:string"><xsd:maxLength value="40"/> <xsd:pattern value="EPSG:[0-9.]+"/>
   </xsd:restriction>			
</xsd:simpleType>	


<xsd:simpleType name="elev-decimal"> 
	<xsd:restriction base="xsd:decimal"><xsd:minInclusive value="-100000.0"/><xsd:maxInclusive value="+100000.0"/>
	</xsd:restriction>
</xsd:simpleType> 

<xsd:simpleType name="indicador_exactitud_geo">	
	<xsd:restriction base="xsd:integer"><xsd:minInclusive value="-1"/><xsd:maxInclusive value="13"/>
  </xsd:restriction>	
</xsd:simpleType>

<xsd:simpleType name="empty-string">
  <xsd:restriction base="xsd:string"> <xsd:enumeration value="" />
  </xsd:restriction>
</xsd:simpleType>

<!-- definició de COORDENADA -->
<xsd:group name="coordenada">
  <xsd:sequence>
	<xsd:element name="latitud">	
		<xsd:simpleType><xsd:restriction base="lat-decimal-or-empty"></xsd:restriction>
		</xsd:simpleType>			
	</xsd:element>					
	<xsd:element name="longitud">				
		<xsd:simpleType><xsd:restriction base="lon-decimal-or-empty"></xsd:restriction>
		</xsd:simpleType>							
	</xsd:element>							
	<xsd:element name="elevacio">	
		<xsd:simpleType><xsd:restriction base="elev-decimal-or-empty"></xsd:restriction>
		</xsd:simpleType>					
	</xsd:element>				
	<xsd:element name="sistema_referencia" >												
		<xsd:simpleType><xsd:restriction base="sr-epsg-or-empty"></xsd:restriction>
		</xsd:simpleType>			
	</xsd:element>
  </xsd:sequence>
</xsd:group>


